{
  "name": "typescript-api",
  "version": "1.0.0",
  "description": "Typescript Node.js API",
  "keywords": [
    "nodejs",
    "typescript",
    "api"
  ],
  "homepage": "https://github.com/bruno-lima1504/node-typescript-api#readme",
  "bugs": {
    "url": "https://github.com/bruno-lima1504/node-typescript-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bruno-lima1504/node-typescript-api.git"
  },
  "license": "ISC",
  "author": "Bruno Lima",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json",
    "start": "yarn build && node dist/src/index.js",
    "start:dev": "ts-node-dev --files 'src/index.ts' | pino-pretty -c",
    "test": "yarn test:unit && yarn test:functional",
    "test:functional": "jest --projects ./test --runInBand",
    "test:unit": "jest",
    "services:run": "docker compose -f infra/compose.yml up -d",
    "services:stop": "docker compose -f infra/compose.yml stop",
    "services:down": "docker compose -f infra/compose.yml down",
    "services:lint:check": "eslint ./src ./test --ext .ts",
    "services:lint:fix": "eslint ./src ./test --ext .ts --fix",
    "services:prettier:check": "prettier -c 'src/**/*.ts' 'test/**/*.ts'",
    "services:prettier:fix": "prettier -w 'src/**/*.ts' 'test/**/*.ts'",
    "services:db:test": "docker rm -f mongodb-test || true && docker run -d -p 27017:27017 --name mongodb-test mongo:latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^6.0.0",
    "@types/config": "^4.4.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-status-codes": "^1.2.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/module-alias": "^2.0.4",
    "@types/mongoose": "^5.11.97",
    "@types/nock": "^11.1.0",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "@types/pino-http": "^6.1.0",
    "@types/supertest": "^7.2.0",
    "cors": "^2.8.6",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@overnightjs/core": "1.7.6",
    "axios": "1.14.0",
    "bcrypt": "6.0.0",
    "body-parser": "2.2.2",
    "config": "4.4.1",
    "express": "5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "9.0.3",
    "module-alias": "2.3.4",
    "mongoose": "9.4.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  }
}
